DB_URL=jdbc:postgresql://localhost:5432/Reception
DB_USERNAME=postgres
DB_PASSWORD=change-me
DB_DRIVER_CLASS_NAME=org.postgresql.Driver
DB_HIKARI_MAXIMUM_POOL_SIZE=10
DB_HIKARI_CONNECTION_TIMEOUT=2000
QWEATHER_BASE_URL=https://nb3yfu3hjd.re.qweatherapi.com
QWEATHER_API_KEY=change-me

# 图片物理存储根目录；留空（或不设置）则回退到应用程序所在目录下的 img 子目录
# （如 /opt/java/app.jar → /opt/java/img）
# IMAGE_STORAGE=/data/reception/images

# —— 后台默认管理员（初始化时播种；未设置则默认 admin / admin123）——
# AUTH_USERNAME=admin
# AUTH_PASSWORD=admin123

# —— 必填密钥（无默认值；未设置或为空将导致启动失败）——
# 生成强随机值（任选其一）：
#   openssl rand -base64 48
#   openssl rand -hex 32
AUTH_JWT_SECRET=change-me-to-a-strong-random-secret-min-32-bytes
AUTH_TOTP_ENC_KEY=change-me-to-a-strong-random-key

# —— CORS 跨域放行来源 ——
# 未设置/为空（DEV 模式）= 放宽任意来源；生产请设为前端确切来源（逗号分隔多个）。
# CORS_ALLOWED_ORIGINS=https://admin.example.com,https://www.example.com

# —— 站点接口限流（令牌桶，按 IP）——
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_CAPACITY=30
# RATE_LIMIT_REFILL_PER_MINUTE=60

# —— 系统初始化控制 ——
# 强制下次启动重新执行初始化：留空=正常；true=安全重跑（admin 已存在则不动）；admin-reset=额外重置管理员口令。
# 处理完成后请删除此行，避免长期悬挂。
# SYSTEM_FORCE_INIT=true
# 审计操作者标识。
# SYSTEM_INIT_ACTOR=env-operator

# —— 首次 / 强制初始化时的"清空重建"路径 ——
# 默认开：检测到需要初始化或 SYSTEM_FORCE_INIT 时，控制台输出醒目警告，需输入 true 后才 drop+create 全部表。
# 关闭（设 false）后退回安全增量 migrate（永不 drop），用于测试 / CI / 容器等无交互或不可破坏的场景。
# SYSTEM_BOOTSTRAP_REBUILD=false
